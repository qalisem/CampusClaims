# Copy this file to .env.local and fill in values for your deployment.

# Public URL of the Supabase API gateway (Kong).
# Local dev:    http://localhost:8000
# On a VM:      http://YOUR_VM_PUBLIC_IP:8000  (or your domain)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Anon key for the Supabase project. Must match the JWT_SECRET in supabase/.env.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps JavaScript API key (Maps JavaScript API + Places API enabled).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
