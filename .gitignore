# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Self-hosted Supabase: runtime data only — keep config files tracked
/supabase/volumes/db/data/
/supabase/volumes/storage/
/supabase/volumes/functions/
/supabase/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS metadata
.DS_Store

# JetBrains IDE settings
.idea/

.env*
!.env.example

# Self-hosted Supabase: runtime data only — keep config files tracked
/supabase/volumes/db/data/
/supabase/volumes/storage/
/supabase/volumes/functions/
/supabase/.env
